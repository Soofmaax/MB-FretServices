# Base URL of the site for canonical URLs and structured data
VITE_SITE_URL=https://mb-fretservices.com

# --- i18n auto-translate (optional) ---
# I18N_TARGET_LANGS=en,pt
# Disable public MT in CI unless explicitly allowed
# I18N_ALLOW_PUBLIC_MT=0
# I18N_LIBRE_MAX_ATTEMPTS=3
# I18N_FILL_WITH_SOURCE=1
# LIBRETRANSLATE_URL=https://libretranslate.com/translate
# Tip: You can use https://libretranslate.de/translate as an alternative public mirror
# LIBRETRANSLATE_API_KEY=your_key
# LINGODEV_API_KEY=your_key
# LINGODEV_API_URL=https://api.lingo.dev/v1/translate